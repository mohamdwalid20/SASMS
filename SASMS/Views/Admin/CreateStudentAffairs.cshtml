@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["AddStaff"];
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    var departments = ViewBag.Departments as List<SASMS.Models.Department>;
}

<div class="form-section" style="max-width: 900px; margin: 0 auto;">
    <h2 class="header-title" style="margin-bottom: 30px;">@Localizer["AddNewStaffMember"]</h2>

    <form asp-action="CreateStudentAffairs" method="post">
        <!-- Show All Validation Errors -->
        <div asp-validation-summary="All" class="validation-summary-box"></div>
        
        <div style="margin-bottom: 30px;">
            <h4 style="color: var(--primary); margin-bottom: 20px; font-size: 18px; font-weight: 600;">@Localizer["AccountDetails"]</h4>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["FullName"] *</label>
                    <input type="text" name="Name" class="form-input" placeholder="@Localizer["EnterFullName"]" required>
                </div>
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["EmailAddress"] *</label>
                    <input type="email" name="Email" class="form-input" placeholder="@Localizer["EnterEmail"]" required>
                </div>
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["PhoneNumber"] *</label>
                    <input type="tel" name="Phone" class="form-input" placeholder="@Localizer["EnterPhone"]" required>
                </div>
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["NationalID"] *</label>
                    <input type="text" name="NationalId" class="form-input" placeholder="@Localizer["EnterNationalID"]" required>
                </div>
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["Password"] *</label>
                    <input type="password" name="Password" class="form-input" placeholder="@Localizer["EnterSecurePassword"]" required>
                </div>
            </div>
        </div>

         <div style="margin-bottom: 30px;">
            <h4 style="color: var(--primary); margin-bottom: 20px; font-size: 18px; font-weight: 600;">@Localizer["JobDetails"]</h4>
            <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["SystemRole"] *</label>
                    <select name="Role" class="form-input" required asp-items="ViewBag.Roles">
                    </select>
                </div>
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["JobTitle"] *</label>
                    <input type="text" name="Position" class="form-input" placeholder="@Localizer["EnterJobTitle"]" required>
                </div>
                <div>
                    <label style="font-size: 14px; font-weight: 600; color: var(--text-dark); margin-bottom: 8px; display: block;">@Localizer["HireDate"]</label>
                    <input type="date" name="HireDate" class="form-input" value="@DateTime.Now.ToString("yyyy-MM-dd")">
                </div>
            </div>
        </div>

        <div style="display: flex; gap: 16px; align-items: center;">
            <button type="submit" class="form-btn">@Localizer["Submit"]</button>
            <a href="@Url.Action("StudentAffairsList", "Admin")" style="color: #A098AE; font-weight: 600; text-decoration: none;">@Localizer["Cancel"]</a>
        </div>
    </form>
</div>
