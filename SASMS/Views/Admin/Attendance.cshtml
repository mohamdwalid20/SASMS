@{
    ViewData["Title"] = "Attendance";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px; margin-bottom: 24px;">
    <div class="metric-card" style="background: white;">
        <div class="metric-lbl">Present Today</div>
        <div class="metric-val" style="color: #4CAF50;">2,340</div>
        <div class="metric-trend" style="color: #4CAF50;"><i class="fas fa-arrow-up"></i> 96%</div>
    </div>
    <div class="metric-card" style="background: white;">
        <div class="metric-lbl">Absent Today</div>
        <div class="metric-val" style="color: #FF5252;">110</div>
        <div class="metric-trend" style="color: #FF5252;"><i class="fas fa-arrow-down"></i> 4%</div>
    </div>
    <div class="metric-card" style="background: white;">
        <div class="metric-lbl">Late Arrivals</div>
        <div class="metric-val" style="color: #FCC43E;">45</div>
        <div class="metric-trend" style="color: #FCC43E;"><i class="fas fa-minus"></i> 2%</div>
    </div>
</div>

<div class="table-card">
    <div class="table-header">
        <h3 style="font-size: 18px; font-weight: 700; color: var(--text-dark); margin: 0;">Attendance Sheet</h3>
        
        <div style="display: flex; gap: 12px; align-items: center;">
            <div class="search-filter">
                 <input type="date" value="@DateTime.Now.ToString("yyyy-MM-dd")" style="border: none; background: transparent; font-family: var(--font); color: var(--text-dark); font-weight: 600;">
            </div>
            <button class="dropdown-btn">
                Select Class <i class="fas fa-chevron-down" style="font-size: 10px; margin-left: 8px;"></i>
            </button>
        </div>
    </div>

    <table class="custom-table">
        <thead>
            <tr>
                <th>Student ID</th>
                <th>Name</th>
                <th>Class</th>
                <th>Time In</th>
                <th>Status</th>
                <th>Action</th>
            </tr>
        </thead>
        <tbody>
            <tr class="row-item">
                <td style="font-weight: 600; color: var(--primary);">#STD-1001</td>
                <td class="user-cell">
                    <img src="https://i.pravatar.cc/150?u=student1">
                    <div>Omar Youssef</div>
                </td>
                <td>5A</td>
                <td>07:45 AM</td>
                <td><span class="status-badge st-paid">Present</span></td>
                <td><button class="action-btn"><i class="far fa-edit"></i></button></td>
            </tr>
            <tr class="row-item">
                <td style="font-weight: 600; color: var(--primary);">#STD-1002</td>
                <td class="user-cell">
                    <img src="https://i.pravatar.cc/150?u=student2">
                    <div>Nour Hassan</div>
                </td>
                <td>3B</td>
                <td>08:15 AM</td>
                <td><span class="status-badge st-overdue" style="background: #FFF4E5; color: #F9AB00;">Late</span></td>
                <td><button class="action-btn"><i class="far fa-edit"></i></button></td>
            </tr>
             <tr class="row-item">
                <td style="font-weight: 600; color: var(--primary);">#STD-1005</td>
                <td class="user-cell">
                    <div style="width: 40px; height: 40px; background: #FFEBEE; border-radius: 50%; display: flex; align-items: center; justify-content: center; color: #FF5252; font-weight: 700;">K</div>
                    <div>Karim Ahmed</div>
                </td>
                <td>4A</td>
                <td>-</td>
                <td><span class="status-badge st-overdue">Absent</span></td>
                <td><button class="action-btn"><i class="far fa-edit"></i></button></td>
            </tr>
        </tbody>
    </table>
</div>
