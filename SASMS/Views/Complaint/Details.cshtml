
@model SASMS.Models.Complaint
@using SASMS.Helpers
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["Complaint Details"];
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<style>
    .details-container {
        max-width: 1200px;
        margin: 0 auto;
        padding-bottom: 50px;
    }

    .details-grid {
        display: grid;
        grid-template-columns: 1fr 360px;
        gap: 30px;
    }

    .glass-card {
        background: white;
        border-radius: 20px;
        border: 1px solid rgba(230, 230, 230, 0.7);
        box-shadow: 0 10px 30px rgba(0, 0, 0, 0.03);
        transition: all 0.3s ease;
    }

    .main-card {
        padding: 40px;
    }

    .badge-status {
        padding: 8px 16px;
        border-radius: 30px;
        font-size: 13px;
        font-weight: 600;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .st-InProgress { background: #E8F0FE; color: #1A73E8; }
    .st-Pending { background: #FFF4E5; color: #FF8C00; }
    .st-Resolved { background: #E6F4EA; color: #1E8E3E; }
    .st-Closed { background: #FEE2E2; color: #DC2626; }

    .complaint-title {
        font-size: 28px;
        font-weight: 800;
        color: #1A202C;
        margin-bottom: 12px;
    }

    .meta-row {
        display: flex;
        flex-wrap: wrap;
        gap: 20px;
        margin-bottom: 30px;
        color: #718096;
        font-size: 14px;
    }

    .meta-item {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .section-header {
        font-size: 14px;
        font-weight: 700;
        color: #A0AEC0;
        text-transform: uppercase;
        letter-spacing: 1px;
        margin-bottom: 15px;
        padding-inline-start: 2px;
    }

    .description-box {
        background: #F8FAFC;
        border-radius: 16px;
        padding: 25px;
        color: #4A5568;
        line-height: 1.8;
        font-size: 16px;
        border: 1px solid #EDF2F7;
        margin-bottom: 35px;
    }

    .data-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 25px;
    }

    .data-item {
        background: #FFFFFF;
        padding: 20px;
        border-radius: 12px;
        border: 1px solid #F1F5F9;
    }

    .data-label {
        font-size: 12px;
        color: #64748B;
        margin-bottom: 8px;
        display: block;
    }

    .data-value {
        font-weight: 700;
        color: #1E293B;
        font-size: 16px;
    }

    .sidebar-card {
        padding: 30px;
        text-align: center;
    }

    .user-avatar-wrapper {
        position: relative;
        width: 100px;
        height: 100px;
        margin: 0 auto 20px;
    }

    .user-avatar {
        width: 100%;
        height: 100%;
        border-radius: 50%;
        object-fit: cover;
        border: 4px solid white;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }

    .contact-info {
        margin-top: 25px;
        padding-top: 20px;
        border-top: 1px solid #F1F5F9;
        text-align: start;
    }

    .contact-row {
        display: flex;
        align-items: center;
        gap: 12px;
        margin-bottom: 12px;
        font-size: 14px;
        color: #475569;
    }

    .contact-row i {
        color: #94A3B8;
        width: 16px;
    }

    .premium-btn {
        width: 100%;
        padding: 14px;
        border-radius: 12px;
        font-weight: 700;
        font-size: 15px;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        transition: all 0.2s ease;
        cursor: pointer;
        border: none;
    }

    .btn-primary-purple {
        background: #7C3AED;
        color: white;
        box-shadow: 0 4px 14px rgba(124, 58, 237, 0.3);
    }

    .btn-primary-purple:hover {
        background: #6D28D9;
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(124, 58, 237, 0.4);
    }

    .btn-soft-red {
        background: #FEF2F2;
        color: #DC2626;
        border: 1px solid #FEE2E2;
    }

    .btn-soft-red:hover {
        background: #FEE2E2;
        transform: translateY(-2px);
    }

    .resolved-banner {
        padding: 20px;
        background: #ECFDF5;
        border-radius: 12px;
        color: #065F46;
        text-align: center;
        border: 1px solid #D1FAE5;
    }

    .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: #64748B;
        font-weight: 600;
        margin-bottom: 25px;
        transition: 0.2s;
        text-decoration: none;
    }

    .back-link:hover { color: #7C3AED; }

    @@media (max-width: 992px) {
        .details-grid { grid-template-columns: 1fr; }
    }
</style>

<div class="details-container">
    <a asp-action="List" class="back-link">
        <i class="fas fa-arrow-right"></i> @Localizer["Back to List"]
    </a>

    <div class="details-grid">
        <div class="main-column">
            <div class="glass-card main-card">
                <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 15px;">
                    <div>
                        <h1 class="complaint-title">@Model.Title</h1>
                        <div class="meta-row">
                            <div class="meta-item">
                                <i class="fas fa-fingerprint"></i>
                                <span>@Localizer["ID"]: #C-@Model.Id.ToString("D4")</span>
                            </div>
                            <div class="meta-item">
                                <i class="far fa-clock"></i>
                                <span>@Model.ComplaintDate.ToString("MMM dd, yyyy hh:mm tt")</span>
                            </div>
                        </div>
                    </div>
                    <div class="badge-status st-@Model.Status.Replace(" ", "")">
                        <span style="width: 8px; height: 8px; border-radius: 50%; background: currentColor;"></span>
                        @Localizer[Model.Status]
                    </div>
                </div>

                <div class="section-header">@Localizer["Description"]</div>
                <div class="description-box">
                    @Model.Description
                </div>

                <div class="section-header">@Localizer["Details"]</div>
                <div class="data-grid">
                    <div class="data-item">
                        <span class="data-label">@Localizer["Category"]</span>
                        <div class="data-value">@Localizer[Model.Category ?? "Other"]</div>
                    </div>
                    <div class="data-item">
                        <span class="data-label">@Localizer["Priority"]</span>
                        <div class="data-value" style="color: @(Model.Priority == "High" ? "#D93025" : Model.Priority == "Medium" ? "#F9AB00" : "#1E8E3E");">
                            @Localizer[Model.Priority ?? "Medium"]
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <div class="sidebar-column">
            <!-- Student Info -->
            <div class="glass-card sidebar-card" style="margin-bottom: 25px;">
                <div class="section-header" style="text-align: center;">@Localizer["Submitted By"]</div>
                
                @if (Model.IsAnonymous)
                {
                    <div class="user-avatar-wrapper">
                        <div class="user-avatar" style="background: #F1F5F9; display: flex; align-items: center; justify-content: center; font-size: 30px; color: #94A3B8;">
                            <i class="fas fa-mask"></i>
                        </div>
                    </div>
                    <div style="font-weight: 800; font-size: 18px; color: #1E293B;">@Localizer["Anonymous Student"]</div>
                    <div style="color: #64748B; font-size: 14px; margin-top: 5px;">@Localizer["Hidden ID"]</div>
                }
                else
                {
                    <div class="user-avatar-wrapper">
                        <img src="@AvatarHelper.GetAvatarUrl(Model.Student?.User?.Name, Model.Student?.ProfilePicturePath ?? Model.Student?.User?.ProfilePicturePath)" class="user-avatar" alt="Avatar">
                    </div>
                    <div style="font-weight: 800; font-size: 18px; color: #1E293B;">@Model.Student?.User?.Name</div>
                    <div style="color: #7C3AED; font-weight: 700; font-size: 14px; margin-top: 5px;">@Localizer["Class"] @Model.Student?.ClassName</div>

                    <div class="contact-info">
                        <div class="contact-row">
                            <i class="far fa-envelope"></i>
                            <span>@Model.Student?.User?.Email</span>
                        </div>
                        <div class="contact-row">
                            <i class="fas fa-phone-alt"></i>
                            <span>@Model.Student?.User?.PhoneNumber</span>
                        </div>
                    </div>
                }
            </div>

            <!-- Actions -->
            <div class="glass-card sidebar-card">
                <div class="section-header" style="text-align: center;">@Localizer["Actions"]</div>
                
                @if (Model.Status != "Resolved" && Model.Status != "Closed")
                {
                    <button class="premium-btn btn-primary-purple" style="margin-bottom: 15px;" onclick="updateStatus(@Model.Id, 'Resolved')">
                        <i class="fas fa-check-circle"></i> @Localizer["Mark as Resolved"]
                    </button>
                    <button class="premium-btn btn-soft-red" onclick="updateStatus(@Model.Id, 'Closed')">
                        <i class="fas fa-times-circle"></i> @Localizer["Close Complaint"]
                    </button>
                }
                else
                {
                    <div class="resolved-banner">
                        <div style="font-size: 40px; margin-bottom: 10px; opacity: 0.8;"><i class="fas fa-check-double"></i></div>
                        <div style="font-weight: 700; font-size: 14px; line-height: 1.6;">
                            @string.Format(Localizer["This complaint is {0}."].Value, Localizer[Model.Status])
                        </div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<script>
    function updateStatus(id, status) {
        let localizedStatus = "";
        if(status === 'Resolved') localizedStatus = "@Localizer["Resolved"]";
        else if(status === 'Closed') localizedStatus = "@Localizer["Closed"]";

        Swal.fire({
            title: "@Localizer["Are you sure?"]",
            text: "@Localizer["ConfirmStatusUpdate"]".replace("{0}", localizedStatus),
            icon: 'warning',
            showCancelButton: true,
            confirmButtonColor: status === 'Resolved' ? '#10B981' : '#EF4444',
            cancelButtonColor: '#94A3B8',
            confirmButtonText: status === 'Resolved' ? "@Localizer["Mark as Resolved"]" : "@Localizer["Close Complaint"]",
            cancelButtonText: "@Localizer["Cancel"]",
            background: '#ffffff',
            customClass: {
                confirmButton: 'premium-swal-confirm',
                cancelButton: 'premium-swal-cancel'
            }
        }).then((result) => {
            if (result.isConfirmed) {
                $.post('/Complaint/UpdateStatus', { id: id, status: status }, function(res) {
                    if(res.success) {
                        Swal.fire({
                            title: "@Localizer["Updated!"]",
                            text: "@Localizer["ComplaintStatusUpdated"]".replace("{0}", localizedStatus),
                            icon: 'success',
                            confirmButtonColor: '#7C3AED'
                        }).then(() => {
                             location.reload();
                        });
                    } else {
                        Swal.fire({
                            title: "@Localizer["Error"]",
                            text: "@Localizer["Error updating status"]",
                            icon: 'error',
                            confirmButtonColor: '#7C3AED'
                        });
                    }
                });
            }
        });
    }
</script>

