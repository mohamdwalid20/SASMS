@model SASMS.Models.Activity
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

@{
    ViewData["Title"] = Localizer["NewActivity"];
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div style="max-width: 900px; margin: 0 auto; padding: 20px;">
    <div class="content-card" style="padding: 32px; border-radius: 16px; background: white; box-shadow: 0 4px 24px rgba(0,0,0,0.05);">
        <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 24px;">
            <h2 class="widget-title" style="margin: 0; display: flex; align-items: center; gap: 12px;">
                <i class="fas fa-calendar-plus" style="color: var(--primary);"></i>
                @Localizer["AddNewActivity"]
            </h2>
            <a asp-action="List" style="color: var(--text-gray); font-size: 13px; text-decoration: none; padding: 8px 16px; border-radius: 8px; border: 1px solid #E0E0E0; display: flex; align-items: center; gap: 8px;">
                <i class="fas fa-arrow-left"></i> @Localizer["BackToList"]
            </a>
        </div>

        <form asp-action="Create" method="post" enctype="multipart/form-data" class="modern-form">
            @Html.AntiForgeryToken()
            <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 20px; font-size: 13px; padding: 12px; background: #FFF5F5; border-radius: 8px; border-right: 4px solid #FF5252;"></div>

            <!-- Image Upload Section -->
            <div style="margin-bottom: 32px; text-align: center;">
                <div id="imagePreviewContainer" style="width: 100%; height: 200px; border-radius: 16px; border: 2px dashed #E0E0E0; display: flex; flex-direction: column; align-items: center; justify-content: center; overflow: hidden; position: relative; background: #FAFAFA; transition: all 0.3s;">
                    <img id="imagePreview" src="#" style="width: 100%; height: 100%; object-fit: cover; display: none;">
                    <div id="uploadPlaceholder">
                        <i class="fas fa-cloud-upload-alt" style="font-size: 32px; color: var(--primary); margin-bottom: 12px;"></i>
                        <div style="font-weight: 600; color: var(--text-dark);">@Localizer["UploadImage"]</div>
                        <div style="font-size: 12px; color: var(--text-gray);">JPG, PNG or WEBP (Max 2MB)</div>
                    </div>
                </div>
                <input type="file" name="image" id="imageInput" accept="image/*" style="display: none;">
                <button type="button" onclick="document.getElementById('imageInput').click()" class="btn" style="margin-top: 16px; padding: 8px 20px; border-radius: 8px; border: 1px solid var(--primary); color: var(--primary); background: transparent; font-size: 13px; font-weight: 600;">
                    <i class="fas fa-image"></i> @Localizer["SelectImage"]
                </button>
            </div>

            <div class="form-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 24px;">
                <!-- Title & Category -->
                <div class="form-group" style="grid-column: span 2;">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["ActivityTitle"]</label>
                    <input asp-for="Title" required class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;" placeholder="@Localizer["EnterActivityTitle"]">
                    <span asp-validation-for="Title" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["Category"]</label>
                    <select asp-for="Category" required class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;">
                        <option value="Sports">@Localizer["Sports"]</option>
                        <option value="Arts">@Localizer["Arts"]</option>
                        <option value="Technology">@Localizer["Technology"]</option>
                        <option value="Academic">@Localizer["Academic"]</option>
                        <option value="Social">@Localizer["Social"]</option>
                        <option value="Volunteer">@Localizer["Volunteer"]</option>
                        <option value="Cultural">@Localizer["Cultural"]</option>
                    </select>
                    <span asp-validation-for="Category" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["Location"]</label>
                    <input asp-for="Location" required class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;" placeholder="@Localizer["EnterLocation"]">
                    <span asp-validation-for="Location" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <!-- Dates -->
                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["StartDate"]</label>
                    <input asp-for="StartDate" type="date" required class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;">
                    <span asp-validation-for="StartDate" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["EndDate"]</label>
                    <input asp-for="EndDate" type="date" required class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;">
                    <span asp-validation-for="EndDate" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <!-- Times -->
                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["StartTime"]</label>
                    <input asp-for="StartTime" type="time" class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;">
                    <span asp-validation-for="StartTime" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["EndTime"]</label>
                    <input asp-for="EndTime" type="time" class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;">
                    <span asp-validation-for="EndTime" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <!-- Registration & Capacity -->
                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 12px; font-weight: 600; color: var(--text-dark);">@Localizer["RequiresRegistration"]</label>
                    <div style="display: flex; gap: 20px; align-items: center;">
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px;">
                            <input type="radio" asp-for="RequiresRegistration" value="true" style="width: 18px; height: 18px;">
                            @Localizer["Yes"]
                        </label>
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px;">
                            <input type="radio" asp-for="RequiresRegistration" value="false" checked style="width: 18px; height: 18px;">
                            @Localizer["No"]
                        </label>
                    </div>
                </div>

                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["RegistrationDeadline"]</label>
                    <input asp-for="RegistrationDeadline" type="datetime-local" class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;">
                    <span asp-validation-for="RegistrationDeadline" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 12px; font-weight: 600; color: var(--text-dark);">@Localizer["Capacity"]</label>
                    <div style="display: flex; gap: 20px; align-items: center; margin-bottom: 12px;">
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px;">
                            <input type="radio" name="capacityType" value="limited" checked onclick="document.getElementById('capacityInput').disabled = false; document.getElementById('capacityInput').required = true;" style="width: 18px; height: 18px;">
                            @Localizer["Limited"]
                        </label>
                        <label style="display: flex; align-items: center; gap: 8px; cursor: pointer; font-size: 14px;">
                            <input type="radio" name="capacityType" value="unlimited" asp-for="IsUnlimitedCapacity" onclick="document.getElementById('capacityInput').disabled = true; document.getElementById('capacityInput').required = false; document.getElementById('capacityInput').value = '';" style="width: 18px; height: 18px;">
                            @Localizer["Unlimited"]
                        </label>
                    </div>
                    <input asp-for="Capacity" type="number" id="capacityInput" class="form-control no-spinner" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;" placeholder="e.g. 30">
                    <span asp-validation-for="Capacity" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["Fee"]</label>
                    <input asp-for="Fee" type="number" step="0.01" class="form-control no-spinner" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;" placeholder="0.00">
                    <span asp-validation-for="Fee" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <!-- Description & Requirements -->
                <div class="form-group" style="grid-column: span 2;">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["Description"]</label>
                    <textarea asp-for="Description" rows="3" class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;" placeholder="@Localizer["EnterActivityDescription"]"></textarea>
                    <span asp-validation-for="Description" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>

                <div class="form-group" style="grid-column: span 2;">
                    <label class="form-label" style="display: block; margin-bottom: 8px; font-weight: 600; color: var(--text-dark);">@Localizer["Requirements"]</label>
                    <textarea asp-for="Requirements" rows="3" class="form-control" style="width: 100%; padding: 12px 16px; border: 1px solid #E0E0E0; border-radius: 12px; outline: none; font-size: 14px;" placeholder="@Localizer["EnterRequirements"]"></textarea>
                    <span asp-validation-for="Requirements" class="text-danger" style="font-size: 12px; margin-top: 4px; display: block;"></span>
                </div>
            </div>

            <div style="margin-top: 32px; display: flex; justify-content: flex-end; gap: 16px; border-top: 1px solid #F0F0F0; padding-top: 24px;">
                <a asp-action="List" class="btn" style="padding: 12px 24px; border-radius: 12px; border: 1px solid #E0E0E0; color: var(--text-gray); text-decoration: none; font-weight: 600; transition: all 0.2s;">@Localizer["Cancel"]</a>
                <button type="submit" class="btn" style="padding: 12px 48px; border-radius: 12px; border: none; background: var(--primary); color: white; font-weight: 600; box-shadow: 0 4px 12px rgba(77, 68, 181, 0.2); cursor: pointer; transition: all 0.2s;">
                    @Localizer["CreateActivity"]
                </button>
            </div>
        </form>
    </div>
</div>

<style>
    .modern-form .form-control:focus {
        border-color: var(--primary) !important;
        box-shadow: 0 0 0 3px rgba(77, 68, 181, 0.1);
    }
    
    /* Remove number input arrows */
    .no-spinner::-webkit-outer-spin-button,
    .no-spinner::-webkit-inner-spin-button {
        -webkit-appearance: none;
        margin: 0;
    }
    
    .no-spinner[type=number] {
        -moz-appearance: textfield;
    }
    
    .btn:hover {
        opacity: 0.9;
        transform: translateY(-1px);
    }

    /* Style for radio buttons in RTL if needed */
    html[dir="rtl"] .form-group div label input[type="radio"] {
        margin-left: 8px;
        margin-right: 0;
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.getElementById('imageInput').onchange = function (evt) {
            const [file] = this.files;
            if (file) {
                document.getElementById('imagePreview').src = URL.createObjectURL(file);
                document.getElementById('imagePreview').style.display = 'block';
                document.getElementById('uploadPlaceholder').style.display = 'none';
                document.getElementById('imagePreviewContainer').style.borderStyle = 'solid';
                document.getElementById('imagePreviewContainer').style.borderColor = 'var(--primary)';
            }
        }
    </script>
}
