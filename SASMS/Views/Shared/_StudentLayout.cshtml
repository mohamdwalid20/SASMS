@using Microsoft.Extensions.Localization


@inject IStringLocalizer<SharedResources> Localizer
@using System.Globalization
@{
    var currentCulture = CultureInfo.CurrentUICulture;
    var currentLang = currentCulture.TwoLetterISOLanguageName;
    var isRtl = currentCulture.TextInfo.IsRightToLeft;
}
<!DOCTYPE html>
<html lang="@currentLang" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | SASMS Student Portal</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @if(isRtl)
    {
        <link rel="stylesheet" href="~/css/rtl.css" asp-append-version="true" />
    }
</head>
@using SASMS.Helpers
<body class="@(User.FindFirst("IsDarkMode")?.Value == "True" ? "dark-mode" : "")">
    <!-- GLOBAL LOADER -->
    <div id="globalLoader" class="global-loader">
        <div class="spinner"></div>
    </div>

    <div class="app-container">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon"><img src="/images/logo remove.png" style="width: 45px; height: auto;"/></div>
                <div class="brand-text">@Localizer["SASMSStudent"]</div>
            </div>

            <nav class="menu-section">
                <!-- Main Label -->
                <div class="menu-label">@Localizer["Menu"]</div>
                
                <a asp-controller="StudentPortal" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Index" && ViewContext.RouteData.Values["Controller"].ToString() == "StudentPortal" ? "active" : "")">
                    <i class="fas fa-th-large"></i> @Localizer["Dashboard"]
                </a>

                <a asp-controller="StudentPortal" asp-action="Complaints" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Complaints" ? "active" : "")">
                    <i class="fas fa-exclamation-circle"></i> @Localizer["Complaints"]
                </a>

                <a asp-controller="StudentPortal" asp-action="Suggestions" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Suggestions" ? "active" : "")">
                    <i class="far fa-lightbulb"></i> @Localizer["Suggestions"]
                </a>
                
                <a asp-controller="StudentPortal" asp-action="Fees" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Fees" ? "active" : "")">
                    <i class="fas fa-wallet"></i> @Localizer["Fees"]
                </a>

                <a asp-controller="StudentPortal" asp-action="Attendance" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Attendance" ? "active" : "")">
                    <i class="far fa-check-circle"></i> @Localizer["Attendance"]
                </a>

                <a asp-controller="StudentPortal" asp-action="Activities" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Activities" ? "active" : "")">
                    <i class="far fa-futbol"></i> @Localizer["Activities"]
                </a>

                <a asp-controller="StudentPortal" asp-action="Messaging" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Messaging" ? "active" : "")">
                    <i class="far fa-comments"></i> @Localizer["Messaging"]
                </a>

           
            </nav>

            <!-- Bottom Menu -->
             <div style="margin-top: auto;">
                <a asp-controller="StudentPortal" asp-action="Settings" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Settings" ? "active" : "")">
                    <i class="fas fa-cog"></i> @Localizer["Settings"]
                </a>
                 <form asp-controller="Account" asp-action="Logout" method="post">
                     <button type="submit" class="nav-link" style="background: none; border: none; width: 100%; text-align: left;">
                        <i class="fas fa-sign-out-alt"></i> @Localizer["Logout"]
                     </button>
                 </form>
             </div>
        </aside>

        <!-- MAIN WRAPPER -->
        <main class="main-wrapper" style="padding-top: 0;">
            <partial name="_Breadcrumb" />
             <header class="top-header" style="margin-top: 20px;">
                <!-- Hamburger (mobile only) -->
                <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle Menu">
                    <i class="fas fa-bars"></i>
                </button>
                <div></div>

                <div class="header-right">
                    
                    <!-- Notifications Dropdown -->
                    @await Component.InvokeAsync("Notification")

                    <div class="profile-pill">
                         <div>
                            <span class="u-name">@User.Identity?.Name</span>
                            <span class="u-role">@Localizer["Student"]</span>
                        </div>
                        <img src="@AvatarHelper.GetAvatarUrl(User.Identity?.Name, User.FindFirst("ProfilePicture")?.Value)" class="u-avatar">
                    </div>
                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success" style="background-color: #d4edda; color: #155724; padding: 15px; margin: 20px; border-radius: 8px; border: 1px solid #c3e6cb;">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger" style="background-color: #f8d7da; color: #721c24; padding: 15px; margin: 20px; border-radius: 8px; border: 1px solid #f5c6cb;">
                    <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                </div>
            }


            @RenderBody()
        </main>
    </div>

    <!-- Sidebar Overlay (Mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="~/js/notifications.js" asp-append-version="true"></script>
    <script>
        // Auto-dismiss alerts after 5 seconds
        document.addEventListener('DOMContentLoaded', function() {
            const alerts = document.querySelectorAll('.alert, .alert-success, .alert-danger');
            if (alerts.length > 0) {
                setTimeout(function() {
                    alerts.forEach(function(alert) {
                        alert.style.transition = 'opacity 0.5s ease-out';
                        alert.style.opacity = '0';
                        setTimeout(function() {
                            alert.style.display = 'none';
                        }, 500);
                    });
                }, 5000);
            }
        });
    </script>

    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        $(document).ready(function() {
            console.log("Initializing Student SignalR and Handlers...");

            // SignalR Connection Setup
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/sasmsHub")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveDataUpdate", function (entityType, action) {
                console.log("Real-time Update received:", entityType, action);
                
                // Show a toast notification using SweetAlert2
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 4000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                Toast.fire({
                    icon: 'info',
                    title: `${entityType} updated.`,
                    text: `${entityType} has been ${action}.`
                });

                const currentController = '@ViewContext.RouteData.Values["Controller"]'.toLowerCase();
                const currentAction = '@ViewContext.RouteData.Values["Action"]'.toLowerCase();
                const entity = entityType.toLowerCase();
                
                // Auto refresh if on the relevant page
                const needsRefresh = 
                    (entity === "complaint" && currentAction === "complaints") ||
                    (entity === "suggestion" && currentAction === "suggestions") ||
                    (entity === "activity" && currentAction === "activities") ||
                    (entity === "attendance" && currentAction === "attendance") ||
                    (entity === "message" && currentAction === "messaging") ||
                    (entity === "fee" && currentAction === "fees") ||
                    (entity === "feesubmission" && currentAction === "fees");
                
                if (needsRefresh) {
                    console.log("Student page needs refresh for " + entityType);
                    setTimeout(() => {
                        location.reload();
                    }, 1000); // Faster refresh
                }
            });

            connection.on("ReceiveNotification", function (message) {
                console.log("Student Notification received:", message);
                Swal.fire({
                    title: 'New Notification',
                    text: message,
                    icon: 'info',
                    confirmButtonColor: 'var(--primary)'
                });
            });

            connection.start().then(function() {
                console.log("Student SignalR Connected Successfully!");
                // Initialize Windows desktop notifications
                if (window.SASMSNotifications) {
                    window.SASMSNotifications.init(connection);
                }
            }).catch(function (err) {
                console.error("Student SignalR Connection Failure: ", err.toString());
            });

            // UI Handlers
            $('#notificationBtn').click(function(e) {
                e.preventDefault();
                e.stopPropagation();
                $('#notificationDropdown').fadeToggle(200);
            });

            $(document).click(function(e) {
                if (!$(e.target).closest('#notificationBtn, #notificationDropdown').length) {
                    $('#notificationDropdown').fadeOut(200);
                }
            });

            $('#markAllReadBtn').click(function(e) {
                e.preventDefault();
                $.ajax({
                    url: '/Notification/MarkAllRead',
                    type: 'POST',
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        }
                    },
                    error: function() {
                        console.error('Failed to mark all as read');
                    }
                });
            });
        });

        // Mobile Sidebar Toggle
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        if (hamburgerBtn && sidebarOverlay) {
            hamburgerBtn.addEventListener('click', function() {
                document.body.classList.toggle('sidebar-open');
                sidebarOverlay.classList.toggle('active');
            });

            sidebarOverlay.addEventListener('click', function() {
                document.body.classList.remove('sidebar-open');
                sidebarOverlay.classList.remove('active');
            });
        }

        // Global Loader Logic
        window.addEventListener('beforeunload', function() {
            document.getElementById('globalLoader').classList.add('active');
        });

        $(document).ajaxStart(function() {
            $('#globalLoader').addClass('active');
        }).ajaxStop(function() {
            $('#globalLoader').removeClass('active');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
