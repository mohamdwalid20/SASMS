@using Microsoft.Extensions.Localization

@inject IStringLocalizer<SharedResources> Localizer
@using System.Globalization
@{
    var currentLang = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
    var isRtl = currentLang == "ar";
}

<!DOCTYPE html>
<html lang="@currentLang" dir="@(isRtl ? "rtl" : "ltr")">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] | SASMS</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @if(isRtl)
    {
        <link rel="stylesheet" href="~/css/rtl.css" asp-append-version="true" />
    }
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="@(User.FindFirst("IsDarkMode")?.Value == "True" ? "dark-mode" : "")">
    <!-- GLOBAL LOADER -->
    <div id="globalLoader" class="global-loader">
        <div class="spinner"></div>
    </div>

    <div class="app-container">
        <!-- SIDEBAR -->
        <aside class="sidebar">
            <div class="brand">
                <div class="brand-icon"><img src="/images/logo remove.png" style="width: 45px; height: auto;"/></div>
                <div class="brand-text">SASMS</div>
            </div>

            <nav class="menu-section">
                <!-- Main Label -->
                <div class="menu-label">@Localizer["Menu"]</div>
                
                <a asp-controller="Admin" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Index" ? "active" : "")">
                    <i class="fas fa-th-large"></i> @Localizer["Dashboard"]
                </a>

                @{
                    var userRoleStr = User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value;
                    var isAdmin = userRoleStr == "Admin" || userRoleStr == "StudentAffairs";
                    var isSupervisor = userRoleStr == "Supervisor";
                    var isActivityTeacher = userRoleStr == "ActivityTeacher";
                }

                @if (isAdmin)
                {
                    <a asp-controller="Application" asp-action="List" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Application" ? "active" : "")">
                        <i class="fas fa-user-plus"></i> @Localizer["Admissions"]
                    </a>
                    
                    <a asp-controller="Student" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Student" ? "active" : "")">
                        <i class="fas fa-user-graduate"></i> @Localizer["Students"]
                    </a>

                    <a asp-controller="Admin" asp-action="StudentAffairsList" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "StudentAffairsList" ? "active" : "")">
                        <i class="fas fa-chalkboard-teacher"></i> @Localizer["Staff"]
                    </a>
                    

                    <a asp-controller="Attendance" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Attendance" ? "active" : "")">
                        <i class="far fa-check-circle"></i> @Localizer["Attendance"]
                    </a>

                    <a asp-controller="Fees" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Fees" ? "active" : "")">
                        <i class="fas fa-wallet"></i> @Localizer["Fees"]
                    </a>
                }

                @if (isAdmin || isSupervisor)
                {
                    <a asp-controller="Complaint" asp-action="List" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Complaint" ? "active" : "")">
                        <i class="fas fa-exclamation-circle"></i> @Localizer["Complaints"]
                    </a>

                    <a asp-controller="Suggestion" asp-action="List" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Suggestion" ? "active" : "")">
                        <i class="far fa-lightbulb"></i> @Localizer["Suggestions"]
                    </a>
                }

                <a asp-controller="Activity" asp-action="List" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "Activity" ? "active" : "")">
                    <i class="far fa-futbol"></i> @Localizer["Activities"]
                </a>

                @if (isAdmin)
                {
                    <a asp-controller="Admin" asp-action="Messaging" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Messaging" ? "active" : "")">
                        <i class="far fa-comments"></i> @Localizer["Messaging"]
                    </a>

                    <a asp-controller="Admin" asp-action="Reports" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "Reports" ? "active" : "")">
                        <i class="far fa-file-alt"></i> @Localizer["Reports"]
                    </a>

                    <a asp-controller="Admin" asp-action="RiskAlerts" class="nav-link @(ViewContext.RouteData.Values["Action"].ToString() == "RiskAlerts" ? "active" : "")">
                        <i class="fas fa-warning"></i> @Localizer["Risk Alerts"]
                    </a>

                    <a asp-controller="DynamicField" asp-action="Index" class="nav-link @(ViewContext.RouteData.Values["Controller"].ToString() == "DynamicField" ? "active" : "")">
                        <i class="fas fa-list-ul"></i> @Localizer["Form Fields"]
                    </a>
                }
            </nav>

            <!-- Bottom Menu -->
             <div style="margin-top: auto;">
                 <a asp-controller="Admin" asp-action="Settings" class="nav-link">
                    <i class="fas fa-cog"></i> @Localizer["Settings"]
                </a>
                 <form asp-controller="Account" asp-action="Logout" method="post">
                     <button type="submit" class="nav-link" style="background: none; border: none; width: 100%; text-align: left;">
                        <i class="fas fa-sign-out-alt"></i> @Localizer["Logout"]
                     </button>
                 </form>
             </div>
        </aside>

        <!-- MAIN WRAPPER -->
        <main class="main-wrapper" style="padding-top: 0;">
            <partial name="_Breadcrumb" />
             <header class="top-header" style="margin-top: 20px;">
                <!-- Hamburger (mobile only) -->
                <button class="hamburger-btn" id="hamburgerBtn" aria-label="Toggle Menu">
                    <i class="fas fa-bars"></i>
                </button>
                <div></div>

                <div class="header-right">
                    
                    <!-- Notifications Dropdown -->
                    @await Component.InvokeAsync("Notification")

                    
@using SASMS.Helpers


                    <div class="profile-pill">
                         <div>
                            <span class="u-name">@User.Identity?.Name</span>
                            <span class="u-role">@Localizer[User.FindFirst(System.Security.Claims.ClaimTypes.Role)?.Value ?? "Admin"]</span>
                        </div>
                        <img src="@AvatarHelper.GetAvatarUrl(User.Identity?.Name, User.FindFirst("ProfilePicture")?.Value)" class="u-avatar">
                    </div>
                </div>
            </header>

            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success" style="background-color: #d4edda; color: #155724; padding: 15px; margin: 20px; border-radius: 8px; border: 1px solid #c3e6cb;">
                    <i class="fas fa-check-circle"></i> @TempData["Success"]
                </div>
            }
            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger" style="background-color: #f8d7da; color: #721c24; padding: 15px; margin: 20px; border-radius: 8px; border: 1px solid #f5c6cb;">
                    <i class="fas fa-exclamation-circle"></i> @TempData["Error"]
                </div>
            }


            @RenderBody()
        </main>
    </div>

    <!-- Sidebar Overlay (Mobile) -->
    <div class="sidebar-overlay" id="sidebarOverlay"></div>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script> <!-- SweetAlert2 -->
    <script src="~/js/site.js" asp-append-version="true"></script> <!-- Ensure site.js is loaded -->
    <script src="~/js/notifications.js" asp-append-version="true"></script> <!-- Windows Notifications -->
    <script>
        // Auto-dismiss alerts after 5 seconds - Vanilla JS
        document.addEventListener('DOMContentLoaded', function() {
            const alerts = document.querySelectorAll('.alert, .alert-success, .alert-danger');
            if (alerts.length > 0) {
                setTimeout(function() {
                    alerts.forEach(function(alert) {
                        alert.style.transition = 'opacity 0.5s ease-out';
                        alert.style.opacity = '0';
                        setTimeout(function() {
                            alert.style.display = 'none';
                        }, 500);
                    });
                }, 5000);
            }
        });

        // Global Client-Side Pagination
        document.addEventListener('DOMContentLoaded', function() {
            const tables = document.querySelectorAll('table.custom-table');
            
            tables.forEach(table => {
                const tbody = table.querySelector('tbody');
                if (!tbody) return;
                
                const rows = Array.from(tbody.querySelectorAll('tr'));
                const rowsPerPage = 10;
                const pageCount = Math.ceil(rows.length / rowsPerPage);
                
                if (pageCount <= 1) return; // No pagination needed
                
                let currentPage = 1;
                
                // Create Pagination Controls
                const container = document.createElement('div');
                container.className = 'pagination-controls';
                container.style.display = 'flex';
                container.style.justifyContent = 'flex-end'; // Right aligned
                container.style.alignItems = 'center';
                container.style.marginTop = '15px';
                container.style.gap = '10px';
                
                // Prev Button
                const prevBtn = document.createElement('button');
                prevBtn.type = 'button'; // Prevent form submission
                prevBtn.innerHTML = '<i class="fas fa-chevron-left"></i>';
                prevBtn.className = 'btn btn-sm btn-outline-secondary';
                prevBtn.style.border = '1px solid #ddd';
                prevBtn.style.background = 'white';
                prevBtn.style.padding = '5px 10px';
                prevBtn.style.borderRadius = '6px';
                prevBtn.style.cursor = 'pointer';
                
                // Next Button
                const nextBtn = document.createElement('button');
                nextBtn.type = 'button'; // Prevent form submission
                nextBtn.innerHTML = '<i class="fas fa-chevron-right"></i>';
                nextBtn.className = 'btn btn-sm btn-outline-secondary';
                nextBtn.style.border = '1px solid #ddd';
                nextBtn.style.background = 'white';
                nextBtn.style.padding = '5px 10px';
                nextBtn.style.borderRadius = '6px';
                nextBtn.style.cursor = 'pointer';
                
                // Info Text
                const infoSpan = document.createElement('span');
                infoSpan.style.fontSize = '14px';
                infoSpan.style.color = '#6c757d';
                infoSpan.style.margin = '0 10px';
                
                // Function to show/hide rows
                function showPage(page) {
                    const start = (page - 1) * rowsPerPage;
                    const end = start + rowsPerPage;
                    
                    rows.forEach((row, index) => {
                        row.style.display = (index >= start && index < end) ? '' : 'none';
                    });
                    
                    // Update controls
                    prevBtn.disabled = page === 1;
                    prevBtn.style.opacity = page === 1 ? '0.5' : '1';
                    
                    nextBtn.disabled = page === pageCount;
                    nextBtn.style.opacity = page === pageCount ? '0.5' : '1';
                    
                    infoSpan.innerText = `Page ${page} of ${pageCount}`;
                }
                
                // Event Listeners
                prevBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (currentPage > 1) {
                        currentPage--;
                        showPage(currentPage);
                    }
                });
                
                nextBtn.addEventListener('click', (e) => {
                    e.preventDefault();
                    if (currentPage < pageCount) {
                        currentPage++;
                        showPage(currentPage);
                    }
                });
                
                // Append
                container.appendChild(prevBtn);
                container.appendChild(infoSpan);
                container.appendChild(nextBtn);
                
                table.parentNode.appendChild(container); // Add after table
                
                // Init
                showPage(1);
            });
        });
    </script>

    <script src="~/lib/signalr/signalr.min.js"></script>
    <script>
        $(document).ready(function() {
            console.log("Initializing SignalR and Page Handlers...");

            // SignalR Connection Setup
            const connection = new signalR.HubConnectionBuilder()
                .withUrl("/sasmsHub")
                .withAutomaticReconnect()
                .build();

            connection.on("ReceiveDataUpdate", function (entityType, action) {
                console.log("Real-time Update received:", entityType, action);
                
                // Show a toast notification using SweetAlert2
                const Toast = Swal.mixin({
                    toast: true,
                    position: 'top-end',
                    showConfirmButton: false,
                    timer: 4000,
                    timerProgressBar: true,
                    didOpen: (toast) => {
                        toast.addEventListener('mouseenter', Swal.stopTimer)
                        toast.addEventListener('mouseleave', Swal.resumeTimer)
                    }
                });

                Toast.fire({
                    icon: 'info',
                    title: `${entityType} has been ${action}.`
                });

                // Automatically refresh specific lists if on the same page
                const currentController = '@ViewContext.RouteData.Values["Controller"]'.toLowerCase();
                const currentAction = '@ViewContext.RouteData.Values["Action"]'.toLowerCase();
                const entity = entityType.toLowerCase();
                
                const needsRefresh = 
                    (currentController === entity) || 
                    (entity === "feesubmission" && currentController === "fees") ||
                    (entity === "fee" && currentController === "fees") ||
                    (entity === "complaint" && currentController === "complaint") ||
                    (entity === "suggestion" && currentController === "suggestion") ||
                    (entity === "activity" && currentController === "activity") ||
                    (entity === "application" && (currentController === "application" || currentController === "admission" || currentController === "applicant")) ||
                    (entity === "resetrequest" && currentController === "admin" && currentAction === "resetrequests") ||
                    (entity === "message" && currentAction === "messaging") ||
                    (entity === "staff" && currentController === "admin" && currentAction.includes("staff"));

                if (needsRefresh) {
                    console.log("Conditions met. Refreshing page for " + entityType);
                    setTimeout(() => {
                        location.reload();
                    }, 1000); // Faster refresh
                }
            });

            connection.on("ReceiveNotification", function (message) {
                console.log("Notification received:", message);
                Swal.fire({
                    title: 'Notification',
                    text: message,
                    icon: 'info',
                    confirmButtonColor: 'var(--primary)'
                });
            });

            connection.start().then(function() {
                console.log("SignalR Connected Successfully!");
                // Initialize Windows desktop notifications
                if (window.SASMSNotifications) {
                    window.SASMSNotifications.init(connection);
                }
            }).catch(function (err) {
                console.error("SignalR Connection Failure: ", err.toString());
            });

            // UI Handlers
            $('#notificationBtn').click(function(e) {
                e.preventDefault();
                e.stopPropagation();
                $('#notificationDropdown').fadeToggle(200);
            });

            $(document).click(function(e) {
                if (!$(e.target).closest('#notificationBtn, #notificationDropdown').length) {
                    $('#notificationDropdown').fadeOut(200);
                }
            });

            $('#markAllReadBtn').click(function(e) {
                e.preventDefault();
                $.ajax({
                    url: '/Notification/MarkAllRead',
                    type: 'POST',
                    success: function(response) {
                        if (response.success) {
                            location.reload();
                        }
                    },
                    error: function() {
                        console.error('Failed to mark all as read');
                    }
                });
            });
        });

        // Mobile Sidebar Toggle
        const hamburgerBtn = document.getElementById('hamburgerBtn');
        const sidebarOverlay = document.getElementById('sidebarOverlay');

        if (hamburgerBtn && sidebarOverlay) {
            hamburgerBtn.addEventListener('click', function() {
                document.body.classList.toggle('sidebar-open');
                sidebarOverlay.classList.toggle('active');
            });

            sidebarOverlay.addEventListener('click', function() {
                document.body.classList.remove('sidebar-open');
                sidebarOverlay.classList.remove('active');
            });
            
            // Close sidebar when clicking a link (optional, but good for UX)
            document.querySelectorAll('.sidebar .nav-link').forEach(link => {
                link.addEventListener('click', () => {
                    document.body.classList.remove('sidebar-open');
                    sidebarOverlay.classList.remove('active');
                });
            });
        }

        // --- Table to Card Helper ---
        function initResponsiveTables() {
            const tables = document.querySelectorAll('.custom-table');
            tables.forEach(table => {
                const headers = Array.from(table.querySelectorAll('thead th')).map(th => th.innerText.trim());
                const rows = table.querySelectorAll('tbody tr');
                
                rows.forEach(row => {
                    const cells = row.querySelectorAll('td');
                    cells.forEach((cell, index) => {
                        if (headers[index] && !cell.getAttribute('data-label')) {
                            cell.setAttribute('data-label', headers[index]);
                        }
                    });
                });
            });
        }

        document.addEventListener('DOMContentLoaded', initResponsiveTables);

        // Global Loader Logic
        window.addEventListener('beforeunload', function() {
            document.getElementById('globalLoader').classList.add('active');
        });

        $(document).ajaxStart(function() {
            $('#globalLoader').addClass('active');
        }).ajaxStop(function() {
            $('#globalLoader').removeClass('active');
        });
    </script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
