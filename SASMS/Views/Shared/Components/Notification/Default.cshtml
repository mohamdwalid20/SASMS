@model IEnumerable<SASMS.Models.Notification>
@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer

<!-- Notifications Dropdown Trigger and Content (rendered by ViewComponent) -->
<div style="position: relative;">
    <button class="icon-btn" id="notificationBtn">
        <i class="far fa-bell"></i>
        @if (Model.Any())
        {
            <span class="badge"></span>
        }
    </button>
    
    <div id="notificationDropdown" class="notification-dropdown" style="display: none; position: absolute; right: 0; top: 50px; width: 320px; background: white; border-radius: 12px; box-shadow: 0 10px 40px rgba(0,0,0,0.15); z-index: 1000; max-height: 400px; overflow-y: auto;">
        <div style="padding: 16px 20px; border-bottom: 1px solid #F0F0F0; display: flex; justify-content: space-between; align-items: center;">
            <h4 style="margin: 0; font-size: 16px; font-weight: 700; color: var(--text-dark);">@Localizer["Notifications"]</h4>
            <span id="markAllReadBtn" style="font-size: 12px; color: var(--primary); cursor: pointer; font-weight: 600;">@Localizer["MarkAllRead"]</span>
        </div>
        
        <div style="padding: 8px 0;">
            @foreach (var note in Model)
            {
                var actionUrl = string.IsNullOrEmpty(note.ActionUrl) ? "#" : note.ActionUrl;
                <div onclick="window.location.href='@actionUrl'" style="padding: 12px 20px; display: flex; gap: 12px; background: #F8F9FF; border-left: 3px solid var(--primary); cursor: pointer; transition: 0.2s;" onmouseover="this.style.background='#F3F4FF'" onmouseout="this.style.background='#F8F9FF'">
                    <div style="width: 40px; height: 40px; border-radius: 50%; background: var(--primary); display: flex; align-items: center; justify-content: center; color: white; font-size: 16px; flex-shrink: 0;">
                        <i class="fas @(note.Type == "Info" ? "fa-info-circle" : note.Type == "Success" ? "fa-check-circle" : "fa-exclamation-circle")"></i>
                    </div>
                    <div style="flex: 1;">
                        <p style="margin: 0 0 4px 0; font-size: 13px; font-weight: 600; color: var(--text-dark);">@Localizer[note.Title]</p>
                        <p style="margin: 0; font-size: 12px; color: var(--text-gray);">@SASMS.Helpers.LocalizationHelper.TranslateNotification(note.Message, Localizer)</p>
                        <span style="font-size: 11px; color: var(--text-gray); margin-top: 4px; display: block;">@note.CreatedAt.ToString("MMM dd, hh:mm tt")</span>
                    </div>
                </div>
            }
            @if (!Model.Any())
            {
                <div style="padding: 20px; text-align: center; color: #A098AE; font-size: 13px;">@Localizer["NoNewNotifications"]</div>
            }
        </div>
        
        <div style="padding: 12px 20px; border-top: 1px solid #F0F0F0; text-align: center;">
            <a href="/Notification/List" style="font-size: 13px; color: var(--primary); font-weight: 600; text-decoration: none;">@Localizer["ViewAllNotifications"]</a>
        </div>
    </div>
</div>
