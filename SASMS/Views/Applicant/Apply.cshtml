@model SASMS.ViewModels.ApplicantApplyViewModel
@{
    ViewData["Title"] = "Apply Now - Student Application";
    Layout = null;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    
    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    
    <!-- Font Awesome -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    
    <style>
        :root {
            --primary: #4D44B5;
            --primary-dark: #3a3390;
            --secondary: #FCC43E;
            --text-dark: #303972;
            --text-gray: #A098AE;
            --bg-body: #F3F4FF;
            --radius: 16px;
        }

        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        body {
            font-family: 'Poppins', sans-serif;
            background-color: var(--bg-body);
            color: var(--text-dark);
            min-height: 100vh;
            padding: 40px 20px;
            display: flex;
            justify-content: center;
            align-items: flex-start;
        }

        .container {
            max-width: 900px;
            width: 100%;
            background: white;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            overflow: hidden;
            position: relative;
        }

        /* Decorative Header Bar */
        .brand-bar {
            height: 8px;
            background: linear-gradient(90deg, var(--primary) 0%, #764ba2 100%);
            width: 100%;
        }

        .header {
            padding: 40px 40px 20px;
            text-align: center;
        }

        .logo-area {
            width: 80px;
            height: 80px;
            background: rgba(77, 68, 181, 0.1);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 20px;
            color: var(--primary);
            font-size: 32px;
        }

        .header h1 {
            font-size: 28px;
            font-weight: 700;
            color: var(--text-dark);
            margin-bottom: 10px;
        }

        .header p {
            font-size: 16px;
            color: var(--text-gray);
            line-height: 1.6;
            max-width: 600px;
            margin: 0 auto;
        }

        .form-content {
            padding: 20px 50px 50px;
        }

        .section-separator {
            margin: 40px 0 30px;
            display: flex;
            align-items: center;
            gap: 15px;
        }

        .section-separator .line {
            flex: 1;
            height: 1px;
            background-color: #E5E7EB;
        }

        .section-separator .title {
            font-size: 16px;
            font-weight: 600;
            color: var(--primary);
            background: rgba(77, 68, 181, 0.08);
            padding: 8px 20px;
            border-radius: 30px;
            display: flex;
            align-items: center;
            gap: 10px;
            white-space: nowrap;
        }

        .form-row {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 24px;
            margin-bottom: 24px;
        }

        .form-group {
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .form-group.full-width {
            grid-column: 1 / -1;
        }

        label {
            font-weight: 600;
            font-size: 14px;
            color: var(--text-dark);
        }

        label .required {
            color: #FF4D4D;
        }

        input, select, textarea {
            padding: 12px 16px;
            border: 1px solid #E5E7EB;
            border-radius: 12px;
            font-family: 'Poppins', sans-serif;
            font-size: 14px;
            color: var(--text-dark);
            background-color: #FAFAFB;
            transition: all 0.3s ease;
        }

        input:focus, select:focus, textarea:focus {
            outline: none;
            border-color: var(--primary);
            background-color: #FFFFFF;
            box-shadow: 0 0 0 4px rgba(77, 68, 181, 0.1);
        }

        ::placeholder {
            color: #A098AE;
        }

        .btn-submit {
            width: 100%;
            padding: 16px;
            background: var(--primary);
            color: white;
            border: none;
            border-radius: 12px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s;
            margin-top: 20px;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 12px;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .btn-submit:hover {
            background: var(--primary-dark);
            transform: translateY(-2px);
            box-shadow: 0 10px 20px rgba(77, 68, 181, 0.2);
        }

        .back-link {
            position: absolute;
            top: 30px;
            left: 30px;
            color: var(--text-gray);
            text-decoration: none;
            font-weight: 500;
            font-size: 14px;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: 0.2s;
        }

        .back-link:hover {
            color: var(--primary);
        }

        .alert {
            padding: 16px;
            border-radius: 12px;
            margin-bottom: 24px;
            font-weight: 500;
            display: flex;
            align-items: center;
            gap: 12px;
            font-size: 14px;
        }

        .alert-success {
            background-color: #DEF7EC;
            color: #03543F;
            border: 1px solid #BCF0DA;
        }

        .alert-danger {
            background-color: #FDE8E8;
            color: #9B1C1C;
            border: 1px solid #FBD5D5;
        }

        /* Hide Number Input Spinners */
        input[type=number]::-webkit-inner-spin-button, 
        input[type=number]::-webkit-outer-spin-button { 
            -webkit-appearance: none; 
            margin: 0; 
        }

        input[type=number] {
            -moz-appearance: textfield;
        }

        .text-danger {
            font-size: 12px;
            color: #FF4D4D;
            font-weight: 500;
        }

        @@media (max-width: 768px) {
            .form-row {
                grid-template-columns: 1fr;
            }
            .header {
                padding: 30px 20px 10px;
            }
            .form-content {
                padding: 20px;
            }
            .back-link {
                position: relative;
                top: auto;
                left: auto;
                margin-bottom: 20px;
                display: inline-flex;
            }
        }
    </style>
</head>
<body>

    <div class="container">
        <div class="brand-bar"></div>
        
        <div class="header">
            <a href="@Url.Action("Index", "Land")" class="back-link">
                <i class="fas fa-arrow-left"></i> Back to Home
            </a>

            <div class="logo-area">
                <i class="fas fa-user-graduate"></i>
            </div>
            <h1>Student Application</h1>
            <p>Please fill out the form below to apply for admission. Ensure all information is accurate and matches your official documents.</p>
        </div>

        <div class="form-content">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success">
                    <i class="fas fa-check-circle"></i>
                    <span>@TempData["Success"]</span>
                </div>
            }

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="alert alert-danger" style="display: block;">
                    <i class="fas fa-exclamation-triangle"></i>
                    <span>Please correct the errors in the form.</span>
                    <ul style="margin-top: 10px; margin-left: 20px; font-size: 13px;">
                        @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                        {
                            <li>@error.ErrorMessage</li>
                        }
                    </ul>
                </div>
            }

            <form asp-action="Apply" method="post" enctype="multipart/form-data">
                @Html.AntiForgeryToken()

                <!-- Personal Info -->
                <div class="section-separator">
                    <div class="line"></div>
                    <div class="title"><i class="fas fa-user"></i> Personal Information</div>
                    <div class="line"></div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Name">Full Name <span class="required">*</span></label>
                        <input asp-for="Name" required placeholder="Full Name as per Birth Certificate">
                        <span asp-validation-for="Name" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="NationalId">National ID <span class="required">*</span></label>
                        <input asp-for="NationalId" required maxlength="14" placeholder="14-digit National ID">
                        <span asp-validation-for="NationalId" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="DateOfBirth">Date of Birth <span class="required">*</span></label>
                        <input asp-for="DateOfBirth" type="date" required>
                        <span asp-validation-for="DateOfBirth" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Gender">Gender <span class="required">*</span></label>
                        <select asp-for="Gender" required>
                            <option value="">-- Select Gender --</option>
                            <option value="Male">Male</option>
                            <option value="Female">Female</option>
                        </select>
                        <span asp-validation-for="Gender" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group full-width">
                    <label asp-for="Address">Current Address <span class="required">*</span></label>
                    <textarea asp-for="Address" rows="2" required placeholder="Governorate - City - Street Name - Building No."></textarea>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Phone">Phone Number <span class="required">*</span></label>
                        <input asp-for="Phone" required placeholder="01xxxxxxxxx">
                        <span asp-validation-for="Phone" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Email">Email Address <span class="required">*</span></label>
                        <input asp-for="Email" required placeholder="example@domain.com">
                        <span asp-validation-for="Email" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-group full-width">
                    <label asp-for="Password">Account Password <span class="required">*</span></label>
                    <input asp-for="Password" type="password" required minlength="8" placeholder="Must be at least 8 characters">
                    <span asp-validation-for="Password" class="text-danger"></span>
                </div>

                <!-- Dynamic Personal Fields -->
                @if (ViewBag.DynamicFields != null)
                {
                    var personalFields = ((IEnumerable<SASMS.Models.DynamicField>)ViewBag.DynamicFields).Where(f => f.Section == SASMS.Models.FormSection.Personal);
                    if (personalFields.Any())
                    {
                        <div class="form-row">
                            @foreach (var field in personalFields)
                            {
                                string val = "";
                                Model.DynamicValues.TryGetValue(field.FieldName, out val);
                                
                                <div class="form-group">
                                    <label>@field.Label @(field.IsRequired ? Html.Raw("<span class='required'>*</span>") : "")</label>
                                    @switch (field.Type)
                                    {
                                        case SASMS.Models.FieldType.Text:
                                            <input type="text" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "") placeholder="@field.Label">
                                            break;
                                        case SASMS.Models.FieldType.Number:
                                            <input type="number" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "") placeholder="@field.Label">
                                            break;
                                        case SASMS.Models.FieldType.Date:
                                            <input type="date" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "")>
                                            break;
                                        case SASMS.Models.FieldType.TextArea:
                                            <textarea name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "") placeholder="@field.Label" rows="2">@val</textarea>
                                            break;
                                        case SASMS.Models.FieldType.Select:
                                            <select name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "")>
                                                <option value="">-- Select @field.Label --</option>
                                                @if (!string.IsNullOrEmpty(field.Options))
                                                {
                                                    foreach (var opt in field.Options.Split(','))
                                                    {
                                                        var trimmedOpt = opt.Trim();
                                                        if (trimmedOpt == val)
                                                        {
                                                            <option value="@trimmedOpt" selected>@trimmedOpt</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@trimmedOpt">@trimmedOpt</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                            break;
                                        case SASMS.Models.FieldType.File:
                                            <input type="file" name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "")>
                                            break;
                                    }
                                    <span class="text-danger">@Html.ValidationMessage($"dyn_{field.FieldName}")</span>
                                </div>
                            }
                        </div>
                    }
                }


                <!-- Academic Info -->
                <div class="section-separator">
                    <div class="line"></div>
                    <div class="title"><i class="fas fa-graduation-cap"></i> Academic Information</div>
                    <div class="line"></div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="Grade">Previous School <span class="required">*</span></label>
                        <input asp-for="Grade" required placeholder="Previous School Name">
                        <span asp-validation-for="Grade" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="GradeOfPrimarySchool">Preparatory Score <span class="required">*</span></label>
                        <input asp-for="GradeOfPrimarySchool" required step="0.5" min="0" max="280" placeholder="Out of 280">
                        <span asp-validation-for="GradeOfPrimarySchool" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="GradeOfEnglishExam">English Score <span class="required">*</span></label>
                        <input asp-for="GradeOfEnglishExam" required step="0.5" min="0" max="60" placeholder="Score">
                        <span asp-validation-for="GradeOfEnglishExam" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="GradeOfMathExam">Math Score <span class="required">*</span></label>
                        <input asp-for="GradeOfMathExam" required step="0.5" min="0" max="60" placeholder="Score">
                        <span asp-validation-for="GradeOfMathExam" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="GradeOfScienceExam">Science Score <span class="required">*</span></label>
                        <input asp-for="GradeOfScienceExam" required step="0.5" min="0" max="60" placeholder="Score">
                        <span asp-validation-for="GradeOfScienceExam" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="PreferredDepartmentId">Preferred Department <span class="required">*</span></label>
                        <select asp-for="PreferredDepartmentId" required>
                            <option value="">-- Select Department --</option>
                            @if (ViewBag.Departments != null)
                            {
                                foreach (var dept in ViewBag.Departments)
                                {
                                    <option value="@dept.Id">@dept.Name</option>
                                }
                            }
                        </select>
                        <span asp-validation-for="PreferredDepartmentId" class="text-danger"></span>
                    </div>
                </div>

                <!-- Dynamic Academic Fields -->
                @if (ViewBag.DynamicFields != null)
                {
                    var academicFields = ((IEnumerable<SASMS.Models.DynamicField>)ViewBag.DynamicFields).Where(f => f.Section == SASMS.Models.FormSection.Academic);
                    if (academicFields.Any())
                    {
                        <div class="form-row">
                            @foreach (var field in academicFields)
                            {
                                string val = "";
                                Model.DynamicValues.TryGetValue(field.FieldName, out val);
                                
                                <div class="form-group">
                                    <label>@field.Label @(field.IsRequired ? Html.Raw("<span class='required'>*</span>") : "")</label>
                                    @switch (field.Type)
                                    {
                                        case SASMS.Models.FieldType.Text:
                                            <input type="text" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "") placeholder="@field.Label">
                                            break;
                                        case SASMS.Models.FieldType.Number:
                                            <input type="number" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "") placeholder="@field.Label">
                                            break;
                                        case SASMS.Models.FieldType.Date:
                                            <input type="date" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "")>
                                            break;
                                        case SASMS.Models.FieldType.TextArea:
                                            <textarea name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "") placeholder="@field.Label" rows="2">@val</textarea>
                                            break;
                                        case SASMS.Models.FieldType.Select:
                                            <select name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "")>
                                                <option value="">-- Select @field.Label --</option>
                                                @if (!string.IsNullOrEmpty(field.Options))
                                                {
                                                    foreach (var opt in field.Options.Split(','))
                                                    {
                                                        var trimmedOpt = opt.Trim();
                                                        if (trimmedOpt == val)
                                                        {
                                                            <option value="@trimmedOpt" selected>@trimmedOpt</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@trimmedOpt">@trimmedOpt</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                            break;
                                        case SASMS.Models.FieldType.File:
                                            <input type="file" name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "")>
                                            break;
                                    }
                                    <span class="text-danger">@Html.ValidationMessage($"dyn_{field.FieldName}")</span>
                                </div>
                            }
                        </div>
                    }
                }


                <!-- Guardian Info -->
                <div class="section-separator">
                    <div class="line"></div>
                    <div class="title"><i class="fas fa-user-shield"></i> Guardian Information</div>
                    <div class="line"></div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="ParentName">Guardian Name <span class="required">*</span></label>
                        <input asp-for="ParentName" required placeholder="Full Name">
                        <span asp-validation-for="ParentName" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="Kinship">Relationship <span class="required">*</span></label>
                        <select asp-for="Kinship" required>
                            <option value="">-- Select --</option>
                            <option value="Father">Father</option>
                            <option value="Mother">Mother</option>
                            <option value="Guardian">Legal Guardian</option>
                        </select>
                        <span asp-validation-for="Kinship" class="text-danger"></span>
                    </div>
                </div>

                <div class="form-row">
                    <div class="form-group">
                        <label asp-for="ParentPhone">Guardian Phone <span class="required">*</span></label>
                        <input asp-for="ParentPhone" required placeholder="01xxxxxxxxx">
                        <span asp-validation-for="ParentPhone" class="text-danger"></span>
                    </div>
                    <div class="form-group">
                        <label asp-for="ParentMajor">Guardian Occupation</label>
                        <input asp-for="ParentMajor" placeholder="Job Title">
                        <span asp-validation-for="ParentMajor" class="text-danger"></span>
                    </div>
                </div>

                <!-- Dynamic Guardian Fields -->
                @if (ViewBag.DynamicFields != null)
                {
                    var guardianFields = ((IEnumerable<SASMS.Models.DynamicField>)ViewBag.DynamicFields).Where(f => f.Section == SASMS.Models.FormSection.Guardian);
                    if (guardianFields.Any())
                    {
                        <div class="form-row">
                            @foreach (var field in guardianFields)
                            {
                                string val = "";
                                Model.DynamicValues.TryGetValue(field.FieldName, out val);
                                
                                <div class="form-group">
                                    <label>@field.Label @(field.IsRequired ? Html.Raw("<span class='required'>*</span>") : "")</label>
                                    @switch (field.Type)
                                    {
                                        case SASMS.Models.FieldType.Text:
                                            <input type="text" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "") placeholder="@field.Label">
                                            break;
                                        case SASMS.Models.FieldType.Number:
                                            <input type="number" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "") placeholder="@field.Label">
                                            break;
                                        case SASMS.Models.FieldType.Date:
                                            <input type="date" name="dyn_@field.FieldName" value="@val" @(field.IsRequired ? "required" : "")>
                                            break;
                                        case SASMS.Models.FieldType.TextArea:
                                            <textarea name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "") placeholder="@field.Label" rows="2">@val</textarea>
                                            break;
                                        case SASMS.Models.FieldType.Select:
                                            <select name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "")>
                                                <option value="">-- Select @field.Label --</option>
                                                @if (!string.IsNullOrEmpty(field.Options))
                                                {
                                                    foreach (var opt in field.Options.Split(','))
                                                    {
                                                        var trimmedOpt = opt.Trim();
                                                        if (trimmedOpt == val)
                                                        {
                                                            <option value="@trimmedOpt" selected>@trimmedOpt</option>
                                                        }
                                                        else
                                                        {
                                                            <option value="@trimmedOpt">@trimmedOpt</option>
                                                        }
                                                    }
                                                }
                                            </select>
                                            break;
                                        case SASMS.Models.FieldType.File:
                                            <input type="file" name="dyn_@field.FieldName" @(field.IsRequired ? "required" : "")>
                                            break;
                                    }
                                    <span class="text-danger">@Html.ValidationMessage($"dyn_{field.FieldName}")</span>
                                </div>
                            }
                        </div>
                    }
                }

                <button type="submit" class="btn-submit">
                    Submit Application <i class="fas fa-paper-plane"></i>
                </button>

            </form>
        </div>
    </div>

    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const form = document.querySelector('form');
            const storageKey = 'sasms_applicant_draft';

            // 1. Load data from localStorage
            const savedData = localStorage.getItem(storageKey);
            if (savedData) {
                try {
                    const data = JSON.parse(savedData);
                    Object.keys(data).forEach(name => {
                        const input = form.querySelector(`[name="${name}"]`);
                        if (input && input.type !== 'password' && input.type !== 'file') {
                            input.value = data[name];
                        }
                    });
                    console.log('Draft restored from local storage.');
                } catch (e) {
                    console.error('Failed to parse draft data:', e);
                }
            }

            // 2. Save data on input/change
            form.addEventListener('input', function(e) {
                const target = e.target;
                if (target.name && target.type !== 'password' && target.type !== 'file') {
                    const currentData = JSON.parse(localStorage.getItem(storageKey) || '{}');
                    currentData[target.name] = target.value;
                    localStorage.setItem(storageKey, JSON.stringify(currentData));
                }
            });

            // 3. Clear storage on successful submit
            form.addEventListener('submit', function() {
                // We keep it until we actually see the success page 
                // but we can clear it if we are sure it's valid.
                // However, the success page itself handles clearing if we redirect there.
            });
        });
    </script>
</body>
</html>
