<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Login to Eva International Applied Technology School portal">
    <title>Login - Eva IATS</title>

    <!-- Brand Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="images/logo%20remove.png" type="image/png">

    <!-- Styles -->
    <link rel="stylesheet" href="/css/login.css">
</head>

<body>
    <!-- Header -->
    <header>
        <div class="container header-container">
            <a href="index.html" class="logo">
                <img src="/images/logo.png" alt="Eva ATS Logo">
            </a>
            <a asp-controller="Land" asp-action="Index" class="back-link">
                <i class="fas fa-arrow-left"></i>
                <span>Back to Home</span>
            </a>
        </div>
    </header>

    <!-- Login Section -->
    <main class="login-main">
        <div class="login-container">
            <!-- Left Side - Branding -->
            <div class="login-branding">
                <div class="branding-content">
                    <img src="/images/logo remove.png" alt="Eva IATS" class="brand-logo">
                    <h1>Welcome Back</h1>
                    <p>Access your Eva International Applied Technology School portal</p>
                    <div class="branding-features">
                        <div class="feature-item">
                            <i class="fas fa-graduation-cap"></i>
                            <span>Student Portal</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-chalkboard-teacher"></i>
                            <span>Faculty Access</span>
                        </div>
                        <div class="feature-item">
                            <i class="fas fa-user-shield"></i>
                            <span>Admin Dashboard</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Side - Login Form -->
            <div class="login-form-wrapper">
                <div class="login-form-container">
                    <div class="form-header">
                        <h2>Sign In</h2>
                        <p>Enter your credentials to access your account</p>
                    </div>

                    <form asp-controller="Account" asp-action="Login" method="post" id="loginForm" class="login-form">
                        <!-- Email Field -->
                        <div class="form-group">
                            <label for="Email">
                                <i class="fas fa-envelope"></i>
                                Email Address
                            </label>
                            <input type="email" id="email" name="Email" placeholder="your.email@example.com" required
                                   autocomplete="email">
                            <span class="error-message" id="emailError"></span>
                        </div>

                        <!-- Password Field -->
                        <div class="form-group">
                            <label for="Password">
                                <i class="fas fa-lock"></i>
                                Password
                            </label>
                            <div class="password-wrapper">
                                <input type="password" id="password" name="Password" placeholder="Enter your password"
                                       required autocomplete="current-password">
                                <button type="button" class="toggle-password" id="togglePassword">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </div>
                            <span class="error-message" id="passwordError"></span>
                        </div>

                        <!-- Remember Me & Forgot Password -->
                        <div class="form-options">
                            <label class="checkbox-label">
                                <input type="checkbox" id="rememberMe" name="rememberMe">
                                <span class="checkbox-custom"></span>
                                <span class="checkbox-text">Remember me</span>
                            </label>
                            <a asp-controller="Account" asp-action="ForgotPassword" class="forgot-link">Forgot Password?</a>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn-login" id="loginBtn">
                            <span class="btn-text">Sign In</span>
                            <span class="btn-loader" style="display: none;">
                                <i class="fas fa-spinner fa-spin"></i>
                            </span>
                        </button>

                        <!-- Alert Message -->
                        @if (TempData["Error"] != null)
                        {
                            <div class="alert-message error" id="alertMessage" style="display: block;">
                                @TempData["Error"]
                            </div>
                        }
                        else
                        {
                            <div class="alert-message" id="alertMessage" style="display: none;"></div>
                        }
                    </form>

                   
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="login-footer">
        <div class="container">
            <p>&copy; 2026 Eva International Applied Technology School. All Rights Reserved.</p>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="/js/login.js" asp-append-version="true"></script>
</body>

</html>