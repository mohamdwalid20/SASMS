<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Reset your Eva IATS password">
    <title>Forgot Password - Eva IATS</title>

    <!-- Brand Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@300;400;500;600;700&display=swap" rel="stylesheet">

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link rel="icon" href="/images/logo remove.png" type="image/png">

    <!-- Styles -->
    <link rel="stylesheet" href="/css/forgot-password.css">
</head>

<body>
    <!-- Header -->
    <header>
        <div class="container header-container">
            <a href="index.html" class="logo">
                <img src="images/logo.png" alt="Eva ATS Logo">
            </a>
            <a asp-controller="Account" asp-action="Login" class="back-link">
                <i class="fas fa-arrow-left"></i>
                <span>Back to Login</span>
            </a>
        </div>
    </header>

    <!-- Forgot Password Section -->
    <main class="forgot-main">
        <div class="forgot-container">
            <!-- Icon Section -->
            <div class="forgot-icon">
                <div class="icon-circle">
                    <i class="fas fa-key"></i>
                </div>
            </div>

            <!-- Form Section -->
            <div class="forgot-form-wrapper">
                <div class="forgot-form-container">
                    <div class="form-header" id="formHeader">
                        <h1>Forgot Password?</h1>
                        <p>
                            No worries! Enter your email address and we'll send a password reset request to the
                            administrator.
                        </p>
                    </div>

                    <form id="forgotPasswordForm" class="forgot-form" method="post">
                        @Html.AntiForgeryToken()
                        <!-- Email Field -->
                        <div class="form-group">
                            <label for="email">
                                <i class="fas fa-envelope"></i>
                                Email Address
                            </label>
                            <input type="email" id="email" name="email" placeholder="your.email@example.com" required
                                   autocomplete="email">
                            <span class="error-message" id="emailError"></span>
                        </div>

                        <!-- Additional Info (Optional) -->
                        <div class="form-group">
                            <label for="reason">
                                <i class="fas fa-comment-dots"></i>
                                Additional Information (Optional)
                            </label>
                            <textarea id="reason" name="reason" rows="3"
                                      placeholder="Provide any additional details that might help verify your identity..."></textarea>
                        </div>

                        <!-- Submit Button -->
                        <button type="submit" class="btn-submit" id="submitBtn">
                            <span class="btn-text">Send Reset Request</span>
                            <span class="btn-loader" style="display: none;">
                                <i class="fas fa-spinner fa-spin"></i>
                            </span>
                        </button>

                        <!-- Alert Message -->
                        <div class="alert-message" id="alertMessage" style="display: none;"></div>
                    </form>

                    <!-- Success State (Hidden by default) -->
                    <div class="success-state" id="successState" style="display: none;">
                        <div class="success-icon">
                            <i class="fas fa-check-circle"></i>
                        </div>
                        <h2>Request Sent Successfully!</h2>
                        <p>
                            Your password reset request has been received. You will receive an email for new password.
                        </p>
                        <div class="success-actions">
                            <a asp-controller="Account" asp-action="Login" class="btn-primary">Return to Login</a>
                            <a asp-controller="Land" asp-action="Index" class="btn-secondary">Go to Homepage</a>
                        </div>
                    </div>

                    <!-- Info Box -->
                    <div class="info-box" id="infoBox">
                        <div class="info-icon">
                            <i class="fas fa-info-circle"></i>
                        </div>
                        <div class="info-content">
                            <h4>How it works</h4>
                            <ul>
                                <li>Enter your registered email address</li>
                                <li>The system will verify if your email exists</li>
                                <li>Your request will be sent to the administrator</li>
                                <li>Admin will verify your identity and reset your password</li>
                                <li>You'll receive an email with your new credentials</li>
                            </ul>
                        </div>
                    </div>

                    <!-- Footer Links -->
                    <div class="form-footer">
                        <p>Remember your password? <a asp-controller="Account" asp-action="Login">Sign In</a></p>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <!-- Footer -->
    <footer class="forgot-footer">
        <div class="container">
            <p>&copy; 2026 Eva International Applied Technology School. All Rights Reserved.</p>
        </div>
    </footer>

    <!-- JavaScript -->
    <script src="/js/forgot-password.js?v=3"></script>
</body>

</html>
