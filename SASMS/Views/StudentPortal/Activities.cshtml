@model IEnumerable<SASMS.Models.Activity>

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Activities"];
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<div class="dashboard-header-modern">
    <div>
        <h1 class="page-title">@Localizer["SchoolActivities"]</h1>
        <p class="page-subtitle">@Localizer["SchoolActivitiesSubtitle"]</p>
    </div>
</div>

@if (!Model.Any())
{
    <div style="text-align: center; padding: 60px; color: var(--text-gray);">
        <i class="fas fa-calendar-times" style="font-size: 50px; margin-bottom: 20px; opacity: 0.5;"></i>
        <p>@Localizer["NoUpcomingActivities"]</p>
    </div>
}
else
{
    <div class="card-grid">
        @foreach (var item in Model)
        {
            <div class="stat-card" style="display: block; padding: 0; overflow: hidden; border: 1px solid #eee; transition: transform 0.2s;">
                <div style="height: 150px; position: relative; overflow: hidden;">
                    @if (!string.IsNullOrEmpty(item.ImagePath))
                    {
                        <img src="@item.ImagePath" style="width: 100%; height: 100%; object-fit: cover;">
                    }
                    else
                    {
                        <div style="width: 100%; height: 100%; background: linear-gradient(135deg, var(--primary), #8e44ad); display: flex; align-items: center; justify-content: center; color: white;">
                             <i class="fas fa-calendar-alt" style="font-size: 40px; opacity: 0.3;"></i>
                        </div>
                    }
                    <span style="position: absolute; top: 12px; right: 12px; background: rgba(0,0,0,0.5); backdrop-filter: blur(4px); color: white; padding: 4px 12px; border-radius: 20px; font-size: 11px; font-weight: 600;">
                        @item.Category
                    </span>
                </div>
                <div style="padding: 20px;">
                    <div style="display: flex; justify-content: space-between; align-items: flex-start; margin-bottom: 8px;">
                        <h3 class="text-dark" style="margin: 0; font-size: 18px; font-weight: 700;">@item.Title</h3>
                    </div>
                    
                    <div class="text-muted" style="margin-bottom: 12px; font-size: 13px; display: flex; align-items: center; gap: 8px;">
                        <i class="far fa-calendar-alt" style="color: var(--primary);"></i> 
                        <span>@item.StartDate.ToString("MMM dd, yyyy")</span>
                        <span style="color: #ddd;">|</span>
                        <i class="far fa-clock" style="color: #FCC43E;"></i>
                        <span>@(item.StartTime.HasValue ? item.StartTime.Value.ToString("hh:mm tt") : Localizer["TBA"])</span>
                    </div>

                    <p style="font-size: 13px; color: #666; line-height: 1.5; margin-bottom: 20px; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; height: 3em;">
                        @item.Description
                    </p>
                    
                    <div style="display: flex; justify-content: space-between; align-items: center; border-top: 1px solid #f5f5f5; padding-top: 15px;">
                        <div style="display: flex; align-items: center; gap: 8px;">
                             @if (!string.IsNullOrEmpty(item.ManagedBy?.ProfilePicturePath))
                             {
                                 <img src="@item.ManagedBy.ProfilePicturePath" style="width: 24px; height: 24px; border-radius: 50%; object-fit: cover;">
                             }
                             else
                             {
                                 <img src="https://ui-avatars.com/api/?name=@item.ManagedBy?.Name&background=random" style="width: 24px; height: 24px; border-radius: 50%;">
                             }
                             <span style="font-size: 12px; font-weight: 500; color: var(--text-dark);">@item.ManagedBy?.Name</span>
                        </div>
                        <a asp-controller="Activity" asp-action="Details" asp-route-id="@item.Id" class="form-btn" style="padding: 6px 16px; font-size: 12px; background: var(--primary); color: white; border-radius: 8px; text-decoration: none;">@Localizer["ViewDetails"]</a>
                    </div>
                </div>
            </div>
        }
    </div>
}

<style>
    .stat-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.1);
    }
</style>
