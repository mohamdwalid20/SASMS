@model SASMS.Models.User

@using Microsoft.Extensions.Localization
@inject IStringLocalizer<SharedResources> Localizer
@{
    ViewData["Title"] = Localizer["Settings"];
    Layout = "~/Views/Shared/_StudentLayout.cshtml";
}

<style>
    .settings-container {
        display: grid;
        grid-template-columns: 240px 1fr;
        gap: 30px;
    }

    .settings-sidebar {
        background: white;
        border-radius: 16px;
        padding: 20px;
        height: fit-content;
    }

    .settings-tab {
        display: flex;
        align-items: center;
        gap: 12px;
        padding: 12px 16px;
        border-radius: 12px;
        color: var(--text-gray);
        font-weight: 500;
        font-size: 14px;
        cursor: pointer;
        transition: 0.2s;
        margin-bottom: 8px;
        text-decoration: none;
    }

    .settings-tab:hover {
        background: #F8F9FF;
        color: var(--primary);
    }

    .settings-tab.active {
        background: var(--primary-light);
        color: var(--primary);
        font-weight: 600;
    }

    .settings-tab i {
        width: 20px;
        font-size: 16px;
    }

    .settings-content {
        background: white;
        border-radius: 16px;
        padding: 30px;
    }

    .settings-section {
        display: none;
    }

    .settings-section.active {
        display: block;
    }

    .section-title {
        font-size: 22px;
        font-weight: 700;
        color: var(--text-dark);
        margin-bottom: 8px;
    }

    .section-desc {
        color: var(--text-gray);
        font-size: 14px;
        margin-bottom: 30px;
    }

    .form-group {
        margin-bottom: 24px;
    }

    .form-group label {
        display: block;
        font-size: 14px;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 8px;
    }

    .form-group input,
    .form-group select {
        width: 100%;
        padding: 12px 16px;
        border: 1px solid #E5E7EB;
        border-radius: 10px;
        font-family: var(--font);
        font-size: 14px;
        color: var(--text-dark);
        transition: 0.2s;
    }

    .form-group input:focus,
    .form-group select:focus {
        border-color: var(--primary);
        outline: none;
        box-shadow: 0 0 0 3px rgba(77, 68, 181, 0.1);
    }

    .profile-upload {
        display: flex;
        align-items: center;
        gap: 24px;
        margin-bottom: 30px;
        padding: 20px;
        background: #F8F9FF;
        border-radius: 12px;
    }

    .profile-avatar {
        width: 100px;
        height: 100px;
        border-radius: 50%;
        background: linear-gradient(135deg, #D3C1FA 0%, #C5B0F5 100%);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 40px;
        font-weight: 700;
        color: white;
    }

    .upload-btn {
        background: var(--primary);
        color: white;
        border: none;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        transition: 0.2s;
    }

    .upload-btn:hover {
        background: #3d35a0;
    }

    .remove-btn {
        background: transparent;
        color: #FF4D4D;
        border: 1px solid #FF4D4D;
        padding: 10px 20px;
        border-radius: 8px;
        font-weight: 600;
        font-size: 13px;
        cursor: pointer;
        transition: 0.2s;
    }

    .remove-btn:hover {
        background: #FFF5F5;
    }

    .toggle-switch {
        position: relative;
        display: inline-block;
        width: 50px;
        height: 26px;
    }

    .toggle-switch input {
        opacity: 0;
        width: 0;
        height: 0;
    }

    .slider {
        position: absolute;
        cursor: pointer;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: #ccc;
        transition: 0.3s;
        border-radius: 34px;
    }

    .slider:before {
        position: absolute;
        content: "";
        height: 20px;
        width: 20px;
        left: 3px;
        bottom: 3px;
        background-color: white;
        transition: 0.3s;
        border-radius: 50%;
    }

    input:checked + .slider {
        background-color: var(--primary);
    }

    input:checked + .slider:before {
        transform: translateX(24px);
    }

    .setting-item {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 16px 0;
        border-bottom: 1px solid #F0F0F0;
    }

    .setting-item:last-child {
        border-bottom: none;
    }

    .setting-info h4 {
        font-size: 15px;
        font-weight: 600;
        color: var(--text-dark);
        margin-bottom: 4px;
    }

    .setting-info p {
        font-size: 13px;
        color: var(--text-gray);
        margin: 0;
    }

    .two-col {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }

    .save-btn {
        background: var(--primary);
        color: white;
        border: none;
        padding: 12px 32px;
        border-radius: 10px;
        font-weight: 600;
        font-size: 14px;
        cursor: pointer;
        transition: 0.2s;
    }

    .save-btn:hover {
        background: #3d35a0;
        transform: translateY(-2px);
        box-shadow: 0 8px 20px rgba(77, 68, 181, 0.3);
    }
</style>

<div class="header-modern">
    <div>
        <h1 style="font-size: 24px; font-weight: 700; color: var(--text-dark);">@Localizer["AccountSettings"]</h1>
        <p style="color: var(--text-gray); margin-top: 5px;">@Localizer["AccountSettingsDesc"]</p>
    </div>
</div>

<div class="settings-container">
    <!-- Sidebar Tabs -->
    <div class="settings-sidebar">
        
        <a href="#" class="settings-tab active" data-tab="profile">
            <i class="far fa-user"></i>
            <span>@Localizer["Profile"]</span>
        </a>
        
        <a href="#" class="settings-tab" data-tab="security">
            <i class="fas fa-lock"></i>
            <span>@Localizer["Security"]</span>
        </a>
        
        <a href="#" class="settings-tab" data-tab="notifications">
            <i class="far fa-bell"></i>
            <span>@Localizer["Notifications"]</span>
        </a>
        
        <a href="#" class="settings-tab" data-tab="appearance">
            <i class="fas fa-palette"></i>
            <span>@Localizer["Appearance"]</span>
        </a>
    </div>

    <!-- Content Area -->
    <div class="settings-content">
        <!-- Profile Section -->
        <div class="settings-section active" id="profile-section">
            <h2 class="section-title">@Localizer["ProfileSettings"]</h2>
            <p class="section-desc">@Localizer["ManagePersonalInfo"]</p>

            <!-- Profile Photo Upload -->
            <form asp-action="UpdateProfile" method="post" enctype="multipart/form-data">
                <div class="profile-upload">
                    <div class="profile-avatar" id="profileAvatar" style="background-image: url('@(!string.IsNullOrEmpty(User.FindFirst("ProfilePicture")?.Value) ? User.FindFirst("ProfilePicture")?.Value : "")'); background-size: cover; background-position: center;">
                        @if(string.IsNullOrEmpty(User.FindFirst("ProfilePicture")?.Value))
                        {
                            @(!string.IsNullOrEmpty(User.Identity?.Name) ? User.Identity.Name.Substring(0, 1).ToUpper() : "A")
                        }
                    </div>
                     <div>
                        <h4 style="font-size: 16px; font-weight: 600; margin-bottom: 8px;">@Localizer["ProfilePicture"]</h4>
                        <p style="font-size: 13px; color: var(--text-gray); margin-bottom: 12px;">PNG, JPG up to 5MB</p>
                        <div style="display: flex; gap: 12px;">
                            <label for="photoUpload" class="upload-btn">
                                <i class="fas fa-upload"></i> @Localizer["UploadPhoto"]
                            </label>
                            <input type="file" id="photoUpload" name="profilePicture" accept="image/*" style="display: none;">
                            <button type="button" class="remove-btn"><i class="far fa-trash-alt"></i> @Localizer["Remove"]</button>
                        </div>
                    </div>
                </div>

                <!-- Profile Form -->
                <div class="two-col">
                    <div class="form-group">
                        <label>@Localizer["FullName"]</label>
                        <input type="text" name="name" value="@Model?.Name" placeholder="@Localizer["EnterFullName"]">
                    </div>
                    <div class="form-group">
                        <label>@Localizer["EmailAddress"]</label>
                        <input type="email" name="email" value="@Model?.Email" placeholder="@Localizer["EnterEmail"]">
                    </div>
                </div>

                <div class="two-col">
                    <div class="form-group">
                        <label>@Localizer["PhoneNumber"]</label>
                        <input type="tel" name="phone" value="@Model?.PhoneNumber" placeholder="+20 123 456 7890">
                    </div>
                    <div class="form-group">
                        <label>@Localizer["Role"]</label>
                        <input type="text" value="@Localizer["Student"]" disabled placeholder="@Localizer["Role"]">
                    </div>
                </div>

                <button type="submit" class="save-btn">@Localizer["SaveChanges"]</button>
            </form>
        </div>

        <!-- Security Section -->
        <div class="settings-section" id="security-section">
            <h2 class="section-title">@Localizer["SecuritySettings"]</h2>
            <p class="section-desc">@Localizer["ManageSecurity"]</p>

            <form asp-action="UpdatePassword" method="post">
                <div class="form-group">
                    <label>@Localizer["CurrentPassword"]</label>
                    <input type="password" name="currentPassword" placeholder="@Localizer["EnterCurrentPassword"]">
                </div>

                <div class="two-col">
                    <div class="form-group">
                        <label>@Localizer["NewPassword"]</label>
                        <input type="password" name="newPassword" placeholder="@Localizer["EnterNewPassword"]">
                    </div>
                    <div class="form-group">
                        <label>@Localizer["ConfirmPassword"]</label>
                        <input type="password" name="confirmPassword" placeholder="@Localizer["ConfirmNewPasswordPlaceholder"]">
                    </div>
                </div>

                <div style="background: #FFF9E5; padding: 16px; border-radius: 10px; margin-bottom: 24px;">
                    <p style="font-size: 13px; color: #856404; margin: 0;">
                        <i class="fas fa-info-circle"></i> @Localizer["PasswordRequirements"]
                    </p>
                </div>

                <button type="submit" class="save-btn">@Localizer["UpdatePassword"]</button>
            </form>
        </div>

        <!-- Notifications Section -->
        <div class="settings-section" id="notifications-section">
            <h2 class="section-title">@Localizer["NotificationPreferences"]</h2>
            <p class="section-desc">@Localizer["ControlNotifications"]</p>

            <form asp-action="UpdatePreferences" method="post">
                @Html.AntiForgeryToken()
                
                <div class="setting-item">
                    <div class="setting-info">
                        <h4>@Localizer["ComplaintUpdates"]</h4>
                        <p>@Localizer["ComplaintUpdateNotificationDesc"]</p>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" name="notifyComplaints" value="true" @(Model.NotifyOnComplaints ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="setting-item">
                    <div class="setting-info">
                        <h4>@Localizer["SchoolAnnouncements"]</h4>
                        <p>@Localizer["SchoolAnnouncementDesc"]</p>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" name="notifyApplications" value="true" @(Model.NotifyOnApplications ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </div>

                <div class="setting-item">
                    <div class="setting-info">
                        <h4>@Localizer["MessageNotifications"]</h4>
                        <p>@Localizer["MessageNotificationDesc"]</p>
                    </div>
                    <label class="toggle-switch">
                        <input type="checkbox" name="notifyMessages" value="true" @(Model.NotifyOnMessages ? "checked" : "")>
                        <span class="slider"></span>
                    </label>
                </div>



                <button type="submit" class="save-btn" style="margin-top: 20px;">@Localizer["SavePreferences"]</button>
            </form>
        </div>

        <!-- Appearance Section -->
        <div class="settings-section" id="appearance-section">
            <h2 class="section-title">@Localizer["Appearance"]</h2>
            <p class="section-desc">@Localizer["CustomizeAppearance"]</p>

            <div class="setting-item">
                <div class="setting-info">
                    <h4>@Localizer["DarkMode"]</h4>
                    <p>@Localizer["DarkModeDesc"]</p>
                </div>
                <label class="toggle-switch">
                    <input type="checkbox" id="darkModeToggle" @(Model.IsDarkMode ? "checked" : "")>
                    <span class="slider"></span>
                </label>
            </div>
            
            <script>
                document.getElementById('darkModeToggle').addEventListener('change', function() {
                    var isDarkMode = this.checked;
                    fetch('@Url.Action("UpdateAppearance", "StudentPortal")', {
                        method: 'POST',
                        body: new URLSearchParams({ darkMode: isDarkMode }),
                        headers: {
                            'Content-Type': 'application/x-www-form-urlencoded',
                            'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                        }
                    })
                    .then(response => response.json())
                    .then(data => {
                        if (data.success) {
                            if (data.isDarkMode) {
                                document.body.classList.add('dark-mode');
                            } else {
                                document.body.classList.remove('dark-mode');
                            }
                        }
                    });
                });
            </script>

            <div class="form-group" style="margin-top: 24px;">
                <label>@Localizer["Language"]</label>
                <select id="languageSelect">
                    <option value="en" selected="@(Model.Language == "en")">@Localizer["English"]</option>
                    <option value="ar" selected="@(Model.Language == "ar")">@Localizer["Arabic"]</option>
                </select>
            </div>

            <button class="save-btn">@Localizer["SaveChanges"]</button>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Tab Switching
        document.querySelectorAll('.settings-tab').forEach(tab => {
            tab.addEventListener('click', (e) => {
                e.preventDefault();
                
                // Remove active class from all tabs
                document.querySelectorAll('.settings-tab').forEach(t => t.classList.remove('active'));
                // Add active to clicked tab
                tab.classList.add('active');
                
                // Hide all sections
                document.querySelectorAll('.settings-section').forEach(s => s.classList.remove('active'));
                // Show selected section
                const tabName = tab.getAttribute('data-tab');
                document.getElementById(tabName + '-section').classList.add('active');
            });
        });

        // Photo Upload Preview
        document.getElementById('photoUpload').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    const avatar = document.getElementById('profileAvatar');
                    avatar.style.backgroundImage = `url(${e.target.result})`;
                    avatar.style.backgroundSize = 'cover';
                    avatar.style.backgroundPosition = 'center';
                    avatar.textContent = '';
                };
                reader.readAsDataURL(file);
            }
        });

        // Language Select Implementation
        document.getElementById('languageSelect').addEventListener('change', function() {
            var selectedLanguage = this.value;
            
            fetch('@Url.Action("UpdateLanguage", "StudentPortal")', {
                method: 'POST',
                body: new URLSearchParams({ language: selectedLanguage }),
                headers: {
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': document.querySelector('input[name="__RequestVerificationToken"]')?.value
                }
            })
            .then(response => response.json())
            .then(data => {
                if (data.success) {
                    location.reload(); 
                }
            });
        });
    </script>
}
